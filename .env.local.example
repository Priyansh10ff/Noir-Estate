# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=your_sanity_token

# Resend Email (https://resend.com)
RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_TO_EMAIL=contact@yourdomain.com

# Cal.com Booking (https://cal.com)
NEXT_PUBLIC_CALCOM_USERNAME=your-calcom-username
NEXT_PUBLIC_CALCOM_EVENT_TYPE=private-viewing

# Admin Dashboard
ADMIN_SECRET=choose_a_strong_password_here

# Site URL
NEXT_PUBLIC_SITE_URL=https://noirestate.com
